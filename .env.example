# Copia este archivo como .env y completa con los valores reales.
# El archivo .env NUNCA debe subirse a GitHub (ya esta en .gitignore).

# --- Servidor ---
PORT=3000

# --- MongoDB ---
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/?appName=tuApp
MONGODB_DB_NAME=vargasyzuniga

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Gmail (envio de correos) ---
GMAIL_USER=correo@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- Correo de la oficina que recibe la notificacion de cada lead ---
# Si no se define, se usa GMAIL_USER como fallback.
OFFICE_NOTIFICATION_EMAIL=contacto@vargasyzuniga.cl

# --- Google Calendar ---
# Pega aqui el CONTENIDO COMPLETO del archivo JSON del Service Account,
# como un solo string (sin saltos de linea reales, usa \n escapados).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}
GOOGLE_CALENDAR_ID=paradisquest@gmail.com

# --- Negocio / Bot ---
NOMBRE_BOT=Renata
NOMBRE_ESTUDIO=Vargas y Zuniga Abogados
UMBRAL_SCORE=70
# Umbral de score para casos sensibles (violencia, abuso, maltrato, etc.)
# Mas bajo porque el bot no hace preguntas de calificacion en esos casos.
UMBRAL_SCORE_SENSIBLE=35

# --- Watcher del PJUD ---
NOMBRES_ABOGADOS=Nombre Completo Abogado Uno|Nombre Completo Abogado Dos
PJUD_WATCHER_INTERVALO_MINUTOS=10

# --- Seguridad del widget embebible ---
# Dominios desde los cuales se permite insertar el chat (separados por
# coma, SIN https:// y SIN barra al final). Cualquier otro sitio que
# intente embeberlo sera rechazado por el navegador.
ALLOWED_EMBED_DOMAINS=vargasyzuniga.cl,www.vargasyzuniga.cl
